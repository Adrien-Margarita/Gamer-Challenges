{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "types": ["node","jest"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./",
    
    "resolveJsonModule": true,
    "skipLibCheck": true,
     "baseUrl": "./",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["./", "validators", "swagger", "@types"],
  "exclude": ["node_modules"]
}