generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model challenge {
  challenge_id   String           @id @default(uuid()) @db.Uuid
  title          String           @unique
  description    String
  image_url      String           @default("")
  rules          String
  user_id        String           @db.Uuid
  game_id        String           @db.Uuid
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  game           game             @relation(fields: [game_id], references: [game_id])
  participation  participation[]
  challenge_vote challenge_vote[]
}

model game {
  game_id      String      @id @db.Uuid
  title        String      @unique
  category     String
  description  String
  release_date DateTime    @db.Timestamp(6)
  image_url    String?
  platform     String
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  updated_at   DateTime?   @default(now()) @db.Timestamp(6)
  challenge    challenge[]
}

model participation {
  participation_id   String               @id @default(uuid()) @db.Uuid
  user_id            String               @db.Uuid
  video_url          String?
  image_url          String?
  description        String
  challenge_id       String               @db.Uuid
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  challenge          challenge            @relation(fields: [challenge_id], references: [challenge_id])
  user               user                 @relation(fields: [user_id], references: [user_id])
  participation_vote participation_vote[]
}

model user {
  user_id              String                 @id @default(uuid()) @db.Uuid
  pseudonym            String                 @unique
  email                String                 @unique
  password_hash        String
  avatar_url           String?
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  participation        participation[]
  challenge_vote       challenge_vote[]
  participation_vote   participation_vote[]
  password_reset_token password_reset_token[]
  role_id              Int
  role                 user_role              @relation("UserToRole", fields: [role_id], references: [role_id])
}

model participation_vote {
  participation_vote_id String        @id @default(uuid()) @db.Uuid
  user_id               String        @db.Uuid
  participation_id      String        @db.Uuid
  user                  user          @relation(fields: [user_id], references: [user_id])
  participation         participation @relation(fields: [participation_id], references: [participation_id])
}

model challenge_vote {
  challenge_vote_id String    @id @default(uuid()) @db.Uuid
  user_id           String    @db.Uuid
  challenge_id      String    @db.Uuid
  user              user      @relation(fields: [user_id], references: [user_id])
  challenge         challenge @relation(fields: [challenge_id], references: [challenge_id])
}

model password_reset_token {
  token_id   String   @id @default(uuid()) @db.Uuid
  token      String   @unique
  email      String
  expires_at DateTime
  create_at  DateTime @default(now())
  user_id    String   @db.Uuid
  user       user?    @relation(fields: [user_id], references: [user_id])
}

model user_role {
  id         String    @id @default(uuid()) @db.Uuid
  role_id    Int       @unique @default(0)
  role_name  String
  created_at DateTime?
  updated_at DateTime?
  users      user[]    @relation("UserToRole")
}
